{
  "name": "@spectotal/direc-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the direc CLI and related Spectotal tooling.",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run build",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "clean": "pnpm -r --if-present run clean",
    "dev:direc": "pnpm --filter direc run dev",
    "direc:own-config:init": "npx --no-install tsx scripts/direcOwnConfigInit.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "pack:direc": "pnpm --filter direc pack --dry-run",
    "precommit": "lint-staged && node ./scripts/run-staged-workspaces.mjs typecheck test",
    "prepare": "husky",
    "release:publish": "node ./scripts/ensure-clean-worktree.mjs && pnpm run check && changeset publish",
    "release:version": "node ./scripts/ensure-clean-worktree.mjs && changeset version && pnpm install --lockfile-only",
    "test": "pnpm run build && pnpm -r --if-present run test",
    "test:workspaces": "pnpm -r --if-present run test",
    "typecheck": "pnpm run build && pnpm -r run typecheck",
    "typecheck:workspaces": "pnpm -r run typecheck"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.28.0"
  }
}
