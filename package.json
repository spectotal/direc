{
  "name": "direc",
  "version": "0.1.0",
  "description": "Spec-driven development tooling for turning specifications into executable workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "direc": "./bin/direc.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build",
    "start": "node ./bin/direc.js"
  },
  "keywords": [
    "cli",
    "spec-driven",
    "developer-tools",
    "tooling"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
