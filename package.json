{
  "name": "@spectotal/direc-monorepo",
  "version": "1.0.0-alpha.0",
  "private": true,
  "description": "Clean-break pipeline architecture for Direc.",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test",
    "clean": "find packages -name dist -type d -prune -exec rm -rf {} +",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm run build && pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.28.0"
  }
}
