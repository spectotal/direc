{
  "name": "@spectotal/direc-source-openspec",
  "version": "1.0.0-alpha.0",
  "description": "OpenSpec source plugin for Direc task and spec pipelines.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "MIT",
  "dependencies": {
    "@spectotal/direc-artifact-contracts": "workspace:*",
    "@spectotal/direc-source-contracts": "workspace:*"
  }
}
