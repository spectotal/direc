{
  "name": "@spectotal/direc-telemetry",
  "version": "0.2.0",
  "description": "Non-invasive telemetry preloader for the Direc runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "import": "./dist/preload.js"
    }
  },
  "engines": {
    "node": ">=18.19"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "import-in-the-middle": "^1.11.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@spectotal/direc-analysis-runtime": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
