{
  "name": "@spectotal/direc-pipeline-manager",
  "version": "1.0.0-alpha.0",
  "description": "Pipeline planning, persistence, and execution runtime for Direc.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts}": [
      "eslint --fix --max-warnings=0",
      "prettier --write --ignore-unknown"
    ],
    "**/*.{md,yaml,yml}": "prettier --write --ignore-unknown"
  },
  "license": "MIT",
  "dependencies": {
    "@spectotal/direc-analysis-contracts": "workspace:*",
    "@spectotal/direc-artifact-contracts": "workspace:*",
    "@spectotal/direc-feedback-contracts": "workspace:*",
    "@spectotal/direc-source-contracts": "workspace:*"
  },
  "devDependencies": {
    "@spectotal/direc-source-git-diff": "workspace:*",
    "@spectotal/direc-source-openspec": "workspace:*",
    "@spectotal/direc-source-repository": "workspace:*",
    "@spectotal/direc-tool-bounds-evaluator": "workspace:*",
    "@spectotal/direc-tool-cluster-builder": "workspace:*",
    "@spectotal/direc-tool-complexity-findings": "workspace:*",
    "@spectotal/direc-tool-js-complexity": "workspace:*",
    "@spectotal/direc-tool-graph-maker": "workspace:*",
    "@spectotal/direc-tool-spec-documents": "workspace:*",
    "@spectotal/direc-tool-spec-conflict": "workspace:*"
  }
}
