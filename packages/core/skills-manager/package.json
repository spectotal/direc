{
  "name": "@spectotal/direc-skills-manager",
  "version": "1.0.0-alpha.0",
  "description": "Canonical skill catalog rendering and provider bundle deployment for Direc.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "catalog"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts}": [
      "eslint --fix --max-warnings=0",
      "prettier --write --ignore-unknown"
    ],
    "**/*.{md,yaml,yml}": "prettier --write --ignore-unknown"
  },
  "license": "MIT"
}
