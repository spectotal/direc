{
  "name": "@spectotal/direc-agent-skills",
  "version": "0.1.0",
  "description": "Repo-local skill and prompt scaffolding for Direc-supported agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "build:watch": "rimraf dist && tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
