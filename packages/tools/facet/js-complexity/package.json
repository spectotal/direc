{
  "name": "@spectotal/direc-tool-js-complexity",
  "version": "1.0.0-alpha.0",
  "description": "Facet JS complexity analysis for Direc pipelines.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts}": [
      "eslint --fix --max-warnings=0",
      "prettier --write --ignore-unknown"
    ],
    "**/*.{md,yaml,yml}": "prettier --write --ignore-unknown"
  },
  "license": "MIT",
  "dependencies": {
    "@spectotal/direc-analysis-contracts": "workspace:*",
    "@spectotal/direc-artifact-contracts": "workspace:*",
    "@typescript-eslint/typescript-estree": "^8.57.2",
    "@typescript-eslint/visitor-keys": "^8.57.2"
  }
}
