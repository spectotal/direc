{
  "name": "direc",
  "version": "0.3.0",
  "description": "Spec-driven development tooling for turning specifications into executable workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "direc": "./bin/direc.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "build:watch": "rimraf dist && tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "dev": "tsx src/main.ts",
    "lint": "eslint . --max-warnings=0",
    "prepack": "npm run build",
    "start": "node ./bin/direc.js",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cli",
    "spec-driven",
    "developer-tools",
    "tooling"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "@spectotal/direc-agent-skills": "workspace:*",
    "@spectotal/direc-analysis-runtime": "workspace:*",
    "@spectotal/direc-automation-runtime": "workspace:*",
    "@spectotal/direc-engine": "workspace:*",
    "@spectotal/direc-viz": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
